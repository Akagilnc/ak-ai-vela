generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model School {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Basic info
  name      String
  nameZh    String?  // Chinese name
  location  String   // e.g. "Ithaca, NY"
  state     String
  ranking   Int?     // US News ranking
  website   String?

  // Programs
  programs  String   // JSON array: ["pre-vet", "animal-science", "biology"]

  // Admissions (CDS data)
  testPolicy              String?  // "required" | "optional" | "free" | "blind"
  acceptanceRate          Float?
  internationalAcceptRate Float?
  medianSAT               Int?
  medianACT               Int?
  sat25th                 Int?     // 25th percentile SAT
  sat75th                 Int?     // 75th percentile SAT
  act25th                 Int?     // 25th percentile ACT
  act75th                 Int?     // 75th percentile ACT
  avgGPA                  Float?   // Average admitted GPA (4.0 scale)
  applicationDeadline     String?  // JSON: {"ED": "Nov 1", "RD": "Jan 15"}

  // International student fields
  internationalStudentPct Float?
  internationalScholarships String? // JSON description
  visaOPTSupport          Boolean  @default(false)
  englishRequirements     String?  // e.g. "TOEFL 100+ / IELTS 7.0+"

  // Financial
  estimatedAnnualCost     Int?     // Total COA in USD
  financialAidPct         Float?   // % of students receiving any aid (broad, may include merit)
  needBasedAidPct         Float?   // % of first-year with need who received aid (CDS H2 D/A)
  needBlind               Boolean  @default(false)

  // Pre-vet / veterinary program classification
  hasPreVetTrack          Boolean  @default(false)
  preVetNotes             String?  // Free text about program strength
  aavmcAccredited         Boolean  @default(false)  // AAVMC-accredited vet school host
  hasVetSchool            Boolean  @default(false)  // University operates its own vet school

  // Data provenance
  dataSource              String?  // e.g. "CDS 2023-2024", "AAVMC 2024", "school admissions page"
  dataSourceUrl           String?  // URL to the primary source document (CDS PDF, admissions page)
  dataSourceRetrievedAt   DateTime?  // When the source was fetched
  lastVerifiedAt          DateTime?  // Last human-verified date (independent of retrieval)
  dataConfidence          String?  // "verified" | "partial" | "estimated" | "unknown"

  // Radar chart dimensions (normalized 0-100)
  radarAcceptance         Float?
  radarInternational      Float?
  radarSAT                Float?
  radarCost               Float?
  radarAid                Float?

  @@unique([name, state])
  @@map("schools")
}

model Student {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  gradeLevel Int?    // Current grade level
  schoolSystem String? // e.g. "public", "international", "private"

  // Academic
  gpaPercentage Float?   // Chinese percentage score (0-100)
  classRank     String?  // e.g. "5/200"
  normalizedGPA Float?   // Computed US 4.0 scale equivalent
  gpaPercentile Float?   // Computed percentile

  // Test scores
  satScore      Int?
  actScore      Int?
  toeflScore    Int?
  ieltsScore    Float?

  // Science specific (pre-vet relevant)
  scienceGPA    Float?   // Science course average if available

  // Target
  targetMajor   String?  // e.g. "pre-vet", "animal-science", "biology"
  targetSchools String?  // JSON array of school IDs

  // Questionnaire results (growth tracking)
  questionnaireResults QuestionnaireResult[]

  @@map("students")
}

model QuestionnaireResult {
  id          String   @id @default(cuid())
  submittedAt DateTime @default(now())

  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])

  // Full questionnaire answers stored as JSON
  // Validated by zod at app layer, not DB layer
  answers     Json

  @@map("questionnaire_results")
}

// ─────────────────────────────────────────────────────────────────────────────
// Path Explorer v0.1 — G1-G3 monthly activity cards
//
// Schema history:
//   - 4/15 design doc: PathCardContent (升学决策卡 17 张) — never migrated
//   - 4/19 pivot:      PathGoal + PathActivity (月度活动卡 5 张)
//
// Seed data lives at docs/research/data/g1-may-seed.ts — types + content
// Cross-record references use `slug` (stable string key), DB IDs are cuid.
// ─────────────────────────────────────────────────────────────────────────────

model PathStage {
  id          String   @id @default(cuid())
  slug        String   @unique  // e.g. "g1-to-g3-foundation"
  title       String
  description String
  gradeFrom   Int
  gradeTo     Int
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goals     PathGoal[]
  decisions PathDecision[]

  @@map("path_stages")
}

model PathGoal {
  id           String   @id @default(cuid())
  slug         String   @unique  // cross-activity reference key
  stageId      String
  stage        PathStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title        String
  rationale    String              // markdown, why this goal matters
  horizon      String              // "month" | "semester" | "annual" |
                                   // "2-year" | "3-year" | "5-year" | "K-12"
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities PathActivity[]

  @@index([stageId])
  @@map("path_goals")
}

model PathActivity {
  id           String   @id @default(cuid())
  slug         String   @unique  // cross-card link reference (gotoActivitySlug)
  goalId       String
  goal         PathGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  month        Int                // 1-12
  cardType     String             // "baseline" | "event"

  // Header / list display metadata
  kicker       String             // e.g. "月度基本盘" / "事件卡 · 节气"
  previews     Json               // string[] of filenames in public/assets/img/
  title        String
  summary      String             // HTML (may contain <b>)
  triggerLabel String              // "周期" | "Trigger"
  triggerText  String             // HTML
  chips        Json               // [{cls, t}] tag chips
  timeText     String             // HTML
  timePct      String             // "≤ 40%" | "一次" | "常驻"

  // Card content (rendered as expanded detail page)
  sections     Json               // ActivitySection[] nested block structure
                                  // Full type def: docs/research/data/g1-may-seed.ts

  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([goalId, month])
  @@map("path_activities")
}

model PathDecision {
  id           String   @id @default(cuid())
  stageId      String
  stage        PathStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  title        String   // e.g. "美高 vs 国内国际学校"
  question     String   // e.g. "G7 开始，你让孩子走哪条路？"
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches PathDecisionBranch[]

  @@index([stageId])
  @@map("path_decisions")
}

model PathDecisionBranch {
  id                   String   @id @default(cuid())
  decisionId           String
  decision             PathDecision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  label                String   // e.g. "转美高"
  shortDescription     String   // e.g. "G8 考 SSAT, G9 入读"
  displayOrder         Int
  // Lookup hint, not decision semantics. v0.5+ upgrades this row with
  // PersonalizedRationale FK for per-user path personalization.
  downstreamStageSlugs Json     // string[] of PathStage.slug

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([decisionId])
  @@map("path_decision_branches")
}

model PathInterest {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  email       String
  budgetRange String?  // "<50k" | "50-100k" | "100-200k" | "200k+"
  childGrade  String?  // "G4" | "G5" | "G6" | "G7" | "G8"
  sourcePath  String   // e.g. "/path" or "/path?variant=v01"
  userAgent   String?  // for bot filtering

  @@unique([email, sourcePath])   // idempotency key for CTA form
  @@index([createdAt])              // admin list + purge queries
  @@map("path_interests")
}
